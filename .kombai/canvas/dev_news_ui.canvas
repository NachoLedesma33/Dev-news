      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Fira+Sans:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  :root {\n    --color-white: #FFFFFF;\n    --color-ghost: #F8F8FF;\n    --color-graphite: #343434;\n    --color-green: #00A550;\n    --color-border: #C0C0C0;\n  }\n\n  body {\n    background-color: var(--color-white);\n    color: var(--color-graphite);\n    font-family: 'Fira Sans', sans-serif;\n    margin: 0;\n  }\n\n  h1, h2, h3, h4, .font-heading {\n    font-family: 'Space Grotesk', sans-serif;\n  }\n\n  .border-dashed-v {\n    border-style: dashed;\n    border-color: var(--color-border);\n  }\n\n  .terminal-btn {\n    border: 1px solid var(--color-graphite);\n    border-radius: 6px;\n    padding: 6px 12px;\n    font-weight: 500;\n    cursor: pointer;\n    background: transparent;\n    transition: all 0.2s ease;\n  }\n\n  .terminal-btn:hover {\n    background-color: var(--color-graphite);\n    color: var(--color-white);\n  }\n\n  .upvote-pill {\n    background-color: var(--color-white);\n    border: 2px solid var(--color-green);\n    color: var(--color-green);\n    border-radius: 6px;\n    padding: 4px 10px;\n    font-weight: 700;\n  }\n</style>\n\n<div class=\"min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <header class=\"h-14 border-b border-dashed border-[var(--color-border)] flex items-center justify-between px-6 sticky top-0 bg-white z-50\" data-kid=\"2\">\n    <div class=\"flex items-center gap-6\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-8 h-8 bg-[var(--color-graphite)] flex items-center justify-center text-white font-bold text-xl rounded-sm\" data-kid=\"5\">D</div>\n        <span class=\"font-heading font-bold text-lg tracking-tight\" data-kid=\"6\">DEV_LOG</span>\n      </div>\n      <nav class=\"hidden md:flex items-center text-sm font-medium text-gray-500 gap-2\" data-kid=\"7\">\n        <span data-kid=\"8\">root</span>\n        <span class=\"ti ti-chevron-right text-xs\" data-kid=\"9\"></span>\n        <span class=\"text-[var(--color-graphite)] font-semibold\" data-kid=\"10\">latest_news</span>\n      </nav>\n    </div>\n\n    <div class=\"flex items-center gap-4\" data-kid=\"11\">\n      <div class=\"relative hidden sm:block\" data-kid=\"12\">\n        <div class=\"absolute inset-y-0 left-3 flex items-center text-gray-400\" data-kid=\"13\">\n          <i class=\"ti ti-search text-lg\" data-kid=\"14\"></i>\n        </div>\n        <input type=\"text\" placeholder=\"Search commands...\" class=\"w-64 pl-10 pr-12 py-1.5 border border-dashed border-[var(--color-border)] rounded-md text-sm focus:outline-none focus:border-[var(--color-graphite)]\" data-kid=\"15\">\n        <div class=\"absolute inset-y-0 right-3 flex items-center\" data-kid=\"16\">\n          <kbd class=\"px-1.5 py-0.5 text-[10px] font-bold text-gray-400 bg-gray-100 rounded border border-gray-200\" data-kid=\"17\">⌘K</kbd>\n        </div>\n      </div>\n      <button class=\"p-2 text-gray-500 hover:text-[var(--color-graphite)]\" data-kid=\"18\">\n        <i class=\"ti ti-bookmarks text-xl\" data-kid=\"19\"></i>\n      </button>\n      <button class=\"p-2 text-gray-500 hover:text-[var(--color-graphite)]\" data-kid=\"20\">\n        <i class=\"ti ti-moon text-xl\" data-kid=\"21\"></i>\n      </button>\n    </div>\n  </header>\n\n  <main class=\"flex-1 max-w-7xl mx-auto w-full p-6\" data-kid=\"22\">\n    \n    <section class=\"grid grid-cols-12 gap-6 mb-12\" data-kid=\"23\">\n      \n      <div class=\"col-span-12 lg:col-span-8 border border-dashed border-[var(--color-border)] p-8 relative\" data-kid=\"24\">\n        <div class=\"absolute top-8 right-8 text-right\" data-kid=\"25\">\n          <div class=\"text-[var(--color-green)] text-5xl font-heading font-bold upvote-counter\" data-target=\"1248\" data-kid=\"26\">0</div>\n          <div class=\"text-xs font-bold text-gray-400 uppercase tracking-widest mt-1\" data-kid=\"27\">Total Upvotes</div>\n        </div>\n        <div class=\"mb-4\" data-kid=\"28\">\n          <span class=\"px-2 py-0.5 bg-[var(--color-ghost)] border border-[var(--color-border)] text-[10px] font-bold uppercase tracking-wider\" data-kid=\"29\">featured_execution</span>\n        </div>\n        <h1 class=\"text-5xl font-heading font-bold leading-tight max-w-xl mb-6\" data-kid=\"30\">Implementing Distributed Consensus in High-Frequency Trading Systems</h1>\n        <div class=\"flex items-center gap-6 text-sm\" data-kid=\"31\">\n          <div class=\"flex items-center gap-2\" data-kid=\"32\">\n            <div class=\"w-6 h-6 rounded-full bg-gray-200\" data-kid=\"33\"></div>\n            <span class=\"font-medium\" data-kid=\"34\">alex_devops</span>\n          </div>\n          <span class=\"text-gray-400\" data-kid=\"35\">2h ago</span>\n          <div class=\"flex items-center gap-1 text-[var(--color-green)]\" data-kid=\"36\">\n            <i class=\"ti ti-messages\" data-kid=\"37\"></i>\n            <span class=\"font-bold\" data-kid=\"38\">256 comments</span>\n          </div>\n        </div>\n        <div class=\"mt-8 flex gap-4\" data-kid=\"39\">\n          <button class=\"terminal-btn flex items-center gap-2\" data-kid=\"40\">\n            <i class=\"ti ti-external-link\" data-kid=\"41\"></i> Read Full Thread\n          </button>\n          <button class=\"p-2 border border-dashed border-[var(--color-border)] rounded-md hover:border-[var(--color-graphite)]\" data-kid=\"42\">\n            <i class=\"ti ti-bookmark\" data-kid=\"43\"></i>\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"col-span-12 lg:col-span-4 flex flex-col gap-6\" data-kid=\"44\">\n        <div class=\"flex-1 border border-dashed border-[var(--color-border)] p-6\" data-kid=\"45\">\n          <h3 class=\"font-heading font-bold text-lg mb-6 flex items-center gap-2\" data-kid=\"46\">\n            <i class=\"ti ti-chart-bar text-[var(--color-green)]\" data-kid=\"47\"></i>\n            Real-time_Metrics\n          </h3>\n          <div class=\"space-y-6\" data-kid=\"48\">\n            <div data-kid=\"49\">\n              <div class=\"flex justify-between text-xs font-bold uppercase tracking-wider mb-2\" data-kid=\"50\">\n                <span data-kid=\"51\">Stories_Today</span>\n                <span class=\"text-[var(--color-green)]\" data-kid=\"52\">84% Capacity</span>\n              </div>\n              <div class=\"h-10 flex gap-1\" data-kid=\"53\">\n                <div class=\"flex-1 bg-[var(--color-green)] h-full\" data-kid=\"54\"></div>\n                <div class=\"flex-1 bg-[var(--color-green)] h-full\" data-kid=\"55\"></div>\n                <div class=\"flex-1 bg-[var(--color-green)] h-full opacity-60\" data-kid=\"56\"></div>\n                <div class=\"flex-1 bg-[var(--color-green)] h-full opacity-30\" data-kid=\"57\"></div>\n                <div class=\"flex-1 bg-gray-100 h-full\" data-kid=\"58\"></div>\n              </div>\n            </div>\n            <div data-kid=\"59\">\n              <div class=\"flex justify-between text-xs font-bold uppercase tracking-wider mb-2\" data-kid=\"60\">\n                <span data-kid=\"61\">Active_Discussions</span>\n                <span class=\"text-[var(--color-green)]\" data-kid=\"62\">14.2k ops/s</span>\n              </div>\n              <div class=\"h-10 flex gap-1 items-end\" data-kid=\"63\">\n                <div class=\"w-full bg-[var(--color-graphite)] h-[40%]\" data-kid=\"64\"></div>\n                <div class=\"w-full bg-[var(--color-graphite)] h-[70%]\" data-kid=\"65\"></div>\n                <div class=\"w-full bg-[var(--color-graphite)] h-[90%]\" data-kid=\"66\"></div>\n                <div class=\"w-full bg-[var(--color-graphite)] h-[55%]\" data-kid=\"67\"></div>\n                <div class=\"w-full bg-[var(--color-graphite)] h-[85%]\" data-kid=\"68\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"bg-[var(--color-graphite)] text-white p-6 border border-dashed border-[var(--color-graphite)]\" data-kid=\"69\">\n          <h4 class=\"text-xs font-bold uppercase tracking-widest text-gray-400 mb-2\" data-kid=\"70\">Terminal_Status</h4>\n          <p class=\"text-sm font-mono leading-relaxed\" data-kid=\"71\">\n            > System: Operational<br data-kid=\"72\">\n            > Updates: 42 new logs<br data-kid=\"73\">\n            > Latency: 14ms\n          </p>\n        </div>\n      </div>\n    </section>\n\n    \n    <section data-kid=\"74\">\n      <div class=\"flex items-center justify-between mb-6\" data-kid=\"75\">\n        <h2 class=\"font-heading font-bold text-2xl tracking-tight\" data-kid=\"76\">Main_Feed.log</h2>\n        <div class=\"flex gap-2\" data-kid=\"77\">\n          <button class=\"px-3 py-1 bg-[var(--color-ghost)] border border-[var(--color-border)] text-xs font-bold uppercase\" data-kid=\"78\">all</button>\n          <button class=\"px-3 py-1 text-xs font-bold uppercase text-gray-400 hover:text-[var(--color-graphite)]\" data-kid=\"79\">trending</button>\n          <button class=\"px-3 py-1 text-xs font-bold uppercase text-gray-400 hover:text-[var(--color-graphite)]\" data-kid=\"80\">newest</button>\n        </div>\n      </div>\n\n      <div class=\"border border-dashed border-[var(--color-border)] overflow-hidden\" data-kid=\"81\">\n        <table class=\"w-full text-left border-collapse\" data-kid=\"82\">\n          <thead data-kid=\"83\">\n            <tr class=\"bg-[var(--color-ghost)] border-b border-dashed border-[var(--color-border)] text-[10px] font-bold uppercase tracking-widest text-gray-500\" data-kid=\"84\">\n              <th class=\"px-6 py-4 w-20\" data-kid=\"85\">SCORE</th>\n              <th class=\"px-6 py-4\" data-kid=\"86\">TITLE_STRING</th>\n              <th class=\"px-6 py-4 w-40\" data-kid=\"87\">EXECUTOR</th>\n              <th class=\"px-6 py-4 w-32 text-right\" data-kid=\"88\">TIMESTAMP</th>\n              <th class=\"px-6 py-4 w-24 text-center\" data-kid=\"89\">ACTIONS</th>\n            </tr>\n          </thead>\n          <tbody class=\"text-sm\" data-kid=\"90\">\n            \n            <tr class=\"border-b border-dashed border-[var(--color-border)] hover:bg-[var(--color-ghost)]\" data-kid=\"91\">\n              <td class=\"px-6 py-5 font-bold text-[var(--color-green)]\" data-kid=\"92\">+842</td>\n              <td class=\"px-6 py-5\" data-kid=\"93\">\n                <div class=\"flex items-center gap-2\" data-kid=\"94\">\n                  <span class=\"font-heading font-bold text-base\" data-kid=\"95\">V8 Engine: Deep dive into the new Maglev compiler</span>\n                  <span class=\"text-xs text-gray-400\" data-kid=\"96\">(v8.dev)</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-5\" data-kid=\"97\">\n                <span class=\"font-medium text-gray-600\" data-kid=\"98\">t_v8_team</span>\n              </td>\n              <td class=\"px-6 py-5 text-right text-gray-400 text-xs\" data-kid=\"99\">45m ago</td>\n              <td class=\"px-6 py-5 text-center\" data-kid=\"100\">\n                <i class=\"ti ti-bookmark text-gray-300 cursor-pointer hover:text-[var(--color-graphite)]\" data-kid=\"101\"></i>\n              </td>\n            </tr>\n            \n            <tr class=\"bg-[var(--color-ghost)] border-b border-dashed border-[var(--color-border)] hover:bg-gray-100\" data-kid=\"102\">\n              <td class=\"px-6 py-5 font-bold text-[var(--color-green)]\" data-kid=\"103\">+512</td>\n              <td class=\"px-6 py-5\" data-kid=\"104\">\n                <div class=\"flex items-center gap-2\" data-kid=\"105\">\n                  <span class=\"font-heading font-bold text-base\" data-kid=\"106\">Why CSS-in-JS is a performance bottleneck in 2026</span>\n                  <span class=\"text-xs text-gray-400\" data-kid=\"107\">(modernweb.com)</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-5\" data-kid=\"108\">\n                <span class=\"font-medium text-gray-600\" data-kid=\"109\">performance_guru</span>\n              </td>\n              <td class=\"px-6 py-5 text-right text-gray-400 text-xs\" data-kid=\"110\">1h ago</td>\n              <td class=\"px-6 py-5 text-center\" data-kid=\"111\">\n                <i class=\"ti ti-bookmark-filled text-[var(--color-green)] cursor-pointer\" data-kid=\"112\"></i>\n              </td>\n            </tr>\n            \n            <tr class=\"border-b border-dashed border-[var(--color-border)] hover:bg-[var(--color-ghost)]\" data-kid=\"113\">\n              <td class=\"px-6 py-5 font-bold text-[var(--color-green)]\" data-kid=\"114\">+215</td>\n              <td class=\"px-6 py-5\" data-kid=\"115\">\n                <div class=\"flex items-center gap-2\" data-kid=\"116\">\n                  <span class=\"font-heading font-bold text-base\" data-kid=\"117\">The rise of WebAssembly in the serverless edge</span>\n                  <span class=\"text-xs text-gray-400\" data-kid=\"118\">(wasm-weekly.org)</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-5\" data-kid=\"119\">\n                <span class=\"font-medium text-gray-600\" data-kid=\"120\">edge_lord</span>\n              </td>\n              <td class=\"px-6 py-5 text-right text-gray-400 text-xs\" data-kid=\"121\">3h ago</td>\n              <td class=\"px-6 py-5 text-center\" data-kid=\"122\">\n                <i class=\"ti ti-bookmark text-gray-300 cursor-pointer hover:text-[var(--color-graphite)]\" data-kid=\"123\"></i>\n              </td>\n            </tr>\n            \n            <tr class=\"bg-[var(--color-ghost)] border-b border-dashed border-[var(--color-border)] hover:bg-gray-100\" data-kid=\"124\">\n              <td class=\"px-6 py-5 font-bold text-[var(--color-green)]\" data-kid=\"125\">+189</td>\n              <td class=\"px-6 py-5\" data-kid=\"126\">\n                <div class=\"flex items-center gap-2\" data-kid=\"127\">\n                  <span class=\"font-heading font-bold text-base\" data-kid=\"128\">Announcing the Zig 0.14.0 Release</span>\n                  <span class=\"text-xs text-gray-400\" data-kid=\"129\">(ziglang.org)</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-5\" data-kid=\"130\">\n                <span class=\"font-medium text-gray-600\" data-kid=\"131\">andrew_rk</span>\n              </td>\n              <td class=\"px-6 py-5 text-right text-gray-400 text-xs\" data-kid=\"132\">5h ago</td>\n              <td class=\"px-6 py-5 text-center\" data-kid=\"133\">\n                <i class=\"ti ti-bookmark text-gray-300 cursor-pointer hover:text-[var(--color-graphite)]\" data-kid=\"134\"></i>\n              </td>\n            </tr>\n            \n            <tr class=\"hover:bg-[var(--color-ghost)]\" data-kid=\"135\">\n              <td class=\"px-6 py-5 font-bold text-[var(--color-green)]\" data-kid=\"136\">+94</td>\n              <td class=\"px-6 py-5\" data-kid=\"137\">\n                <div class=\"flex items-center gap-2\" data-kid=\"138\">\n                  <span class=\"font-heading font-bold text-base\" data-kid=\"139\">Post-quantum cryptography is now the default in OpenSSH</span>\n                  <span class=\"text-xs text-gray-400\" data-kid=\"140\">(security.net)</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-5\" data-kid=\"141\">\n                <span class=\"font-medium text-gray-600\" data-kid=\"142\">cyber_sec</span>\n              </td>\n              <td class=\"px-6 py-5 text-right text-gray-400 text-xs\" data-kid=\"143\">8h ago</td>\n              <td class=\"px-6 py-5 text-center\" data-kid=\"144\">\n                <i class=\"ti ti-bookmark text-gray-300 cursor-pointer hover:text-[var(--color-graphite)]\" data-kid=\"145\"></i>\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n      \n      <div class=\"mt-8 flex justify-center\" data-kid=\"146\">\n        <button class=\"terminal-btn flex items-center gap-2 px-8 py-3\" data-kid=\"147\">\n          Fetch More Logs <span class=\"text-xs opacity-50\" data-kid=\"148\">--all</span>\n        </button>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"border-t border-dashed border-[var(--color-border)] p-6 bg-[var(--color-ghost)]\" data-kid=\"149\">\n    <div class=\"max-w-7xl mx-auto w-full flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-bold uppercase tracking-widest text-gray-400\" data-kid=\"150\">\n      <div class=\"flex items-center gap-4\" data-kid=\"151\">\n        <span data-kid=\"152\">© 2026 DEV_LOG_CORP</span>\n        <span class=\"ti ti-point\" data-kid=\"153\"></span>\n        <span data-kid=\"154\">Build v4.2.0-stable</span>\n      </div>\n      <div class=\"flex gap-8\" data-kid=\"155\">\n        <a href=\"#\" class=\"hover:text-[var(--color-graphite)]\" data-kid=\"156\">Documentation</a>\n        <a href=\"#\" class=\"hover:text-[var(--color-graphite)]\" data-kid=\"157\">API Reference</a>\n        <a href=\"#\" class=\"hover:text-[var(--color-graphite)]\" data-kid=\"158\">System Status</a>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<script type=\"module\" data-kid=\"159\">\n  import { animate } from 'https://esm.sh/animejs@4';\n\n  // Rolling counter for upvotes\n  const counters = document.querySelectorAll('.upvote-counter');\n  counters.forEach(el => {\n    const target = parseInt(el.getAttribute('data-target'));\n    const state = { value: 0 };\n    animate(state, {\n      value: target,\n      duration: 2000,\n      round: 1,\n      easing: 'easeOutQuart',\n      onUpdate: () => {\n        el.textContent = state.value.toLocaleString();\n      }\n    });\n  });\n\n  // Simple Entrance Reveals\n  animate('section', {\n    opacity: [0, 1],\n    translateY: [20, 0],\n    duration: 800,\n    delay: (el, i) => i * 150,\n    easing: 'easeOutCubic'\n  });\n</script>",
