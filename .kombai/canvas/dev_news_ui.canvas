    "var_6fd08f727bb5": {
      "type": "variant",
      "label": "Editorial Newspaper UI",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 2760,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@400;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-sans { font-family: 'Source Sans 3', sans-serif; }\n\n  /* Custom selection color for that editorial feel */\n  ::selection {\n    background: #1560BD;\n    color: white;\n  }\n\n  /* Animation mask for headline */\n  .line-mask {\n    overflow: hidden;\n    display: block;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[#F4F0EC] text-[#1B1B1B] font-sans selection:bg-[#1560BD] selection:text-white\" data-kid=\"1\">\n  \n  <header class=\"sticky top-0 z-50 bg-[#F4F0EC] border-b-[3px] border-[#1B1B1B] border-double\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto px-6 py-6 flex items-center justify-between relative\" data-kid=\"3\">\n      \n      <div class=\"flex-1 flex items-center gap-4 group\" data-kid=\"4\">\n        <i class=\"ti ti-search text-xl cursor-pointer hover:text-[#1560BD] transition-colors\" data-kid=\"5\"></i>\n        <input type=\"text\" placeholder=\"Search the archive...\" class=\"bg-transparent border-none outline-hidden text-sm w-0 group-hover:w-48 transition-all duration-300 font-sans\" data-kid=\"6\">\n      </div>\n\n      \n      <div class=\"absolute left-1/2 -translate-x-1/2 text-center\" data-kid=\"7\">\n        <h1 class=\"font-serif text-5xl font-black tracking-tighter uppercase leading-none\" data-kid=\"8\">\n          Dev <span class=\"text-[#1560BD]\" data-kid=\"9\">News</span>\n        </h1>\n        <p class=\"text-[10px] uppercase tracking-[0.2em] font-semibold mt-1 opacity-60\" data-kid=\"10\">Volume IV • Issue 182 • July 04, 2026</p>\n      </div>\n\n      \n      <div class=\"flex-1 flex items-center justify-end gap-6\" data-kid=\"11\">\n        <button class=\"flex items-center gap-2 hover:text-[#1560BD] transition-colors\" data-kid=\"12\">\n          <i class=\"ti ti-bookmarks text-xl\" data-kid=\"13\"></i>\n          <span class=\"text-xs uppercase font-bold tracking-wider hidden sm:inline\" data-kid=\"14\">Bookmarks</span>\n        </button>\n        <button class=\"hover:text-[#1560BD] transition-colors\" data-kid=\"15\">\n          <i class=\"ti ti-sun text-xl\" data-kid=\"16\"></i>\n        </button>\n      </div>\n    </div>\n  </header>\n\n  <main class=\"max-w-7xl mx-auto px-6 pt-12 pb-24\" data-kid=\"17\">\n    \n    <section class=\"mb-16 border-b border-[#1B1B1B] pb-16\" data-kid=\"18\">\n      <div class=\"grid lg:grid-cols-12 gap-12 items-start\" data-kid=\"19\">\n        <div class=\"lg:col-span-8\" data-kid=\"20\">\n          <div class=\"mb-6 flex items-center gap-4 text-[11px] font-bold uppercase tracking-widest text-[#1560BD]\" data-kid=\"21\">\n            <span class=\"px-2 py-0.5 border border-[#1560BD]\" data-kid=\"22\">Top Story</span>\n            <span class=\"text-[#1B1B1B]/60\" data-kid=\"23\">5 min read</span>\n          </div>\n          <h2 class=\"hero-headline font-serif text-7xl font-black leading-[1.05] tracking-tight mb-8\" data-kid=\"24\">\n            <span class=\"line-mask\" data-kid=\"25\">The Future of</span>\n            <span class=\"line-mask\" data-kid=\"26\">Distributed Computing</span>\n            <span class=\"line-mask\" data-kid=\"27\">in a Post-Cloud Era</span>\n          </h2>\n          <div class=\"grid md:grid-cols-2 gap-8\" data-kid=\"28\">\n            <div data-kid=\"29\">\n              <p class=\"text-lg leading-relaxed opacity-90 mb-6\" data-kid=\"30\">\n                As edge computing matures, the centralized cloud model faces unprecedented scrutiny. We explore how decentralization is reshaping the developer's mental model and the infrastructure required to support it.\n              </p>\n              <div class=\"flex items-center gap-4 border-t border-[#1B1B1B]/10 pt-4\" data-kid=\"31\">\n                <div class=\"w-10 h-10 bg-[#1B1B1B] rounded-none flex items-center justify-center text-[#F4F0EC] font-serif font-bold\" data-kid=\"32\">JD</div>\n                <div data-kid=\"33\">\n                  <p class=\"text-xs font-bold uppercase tracking-wider\" data-kid=\"34\">Jane Doe</p>\n                  <p class=\"text-[10px] text-[#1B1B1B]/50 uppercase\" data-kid=\"35\">Principal Architect @ Vercel</p>\n                </div>\n              </div>\n            </div>\n            <div class=\"hidden md:block border-l border-[#1B1B1B]/10 pl-8 italic text-[#1B1B1B]/70 leading-relaxed\" data-kid=\"36\">\n              \"We aren't just moving workloads; we are fundamentally redefining where data lives and how it's accessed at the speed of light.\"\n            </div>\n          </div>\n        </div>\n        <div class=\"lg:col-span-4 h-full\" data-kid=\"37\">\n          <div class=\"relative h-full min-h-[400px] border-2 border-[#1B1B1B] p-1\" data-kid=\"38\">\n             <div class=\"absolute inset-1 border border-[#1B1B1B]/20\" data-kid=\"39\"></div>\n             <img src=\"https://images.unsplash.com/photo-1581508512961-0e3b9524db40?auto=format&w=800&q=80&fit=crop\" alt=\"Lennert Naessens on Unsplash\" class=\"w-full h-full object-cover grayscale contrast-125\" decoding=\"async\" loading=\"lazy\" data-kid=\"40\">\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section data-kid=\"41\">\n      <div class=\"flex items-center justify-between mb-8 border-y border-[#1B1B1B] py-3\" data-kid=\"42\">\n        <h3 class=\"font-serif text-2xl font-bold italic tracking-tight uppercase\" data-kid=\"43\">The Wire</h3>\n        <div class=\"flex gap-4 text-[10px] font-bold uppercase tracking-widest\" data-kid=\"44\">\n          <button class=\"text-[#1560BD] underline decoration-2 underline-offset-4\" data-kid=\"45\">Latest</button>\n          <button class=\"opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"46\">Popular</button>\n          <button class=\"opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"47\">Discussions</button>\n        </div>\n      </div>\n\n      <div class=\"columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8\" data-kid=\"48\">\n        \n        <article class=\"story-card break-inside-avoid bg-white border border-[#1B1B1B] p-6 hover:shadow-[8px_8px_0px_0px_#1560BD] transition-all duration-300 cursor-pointer group\" data-kid=\"49\">\n          <div class=\"flex justify-between items-start mb-4\" data-kid=\"50\">\n            <span class=\"text-[10px] font-bold uppercase tracking-tighter text-[#1560BD]\" data-kid=\"51\">Security</span>\n            <i class=\"ti ti-bookmark text-lg hover:text-[#1560BD]\" data-kid=\"52\"></i>\n          </div>\n          <h4 class=\"font-serif text-xl font-black leading-snug mb-3 group-hover:text-[#1560BD] transition-colors\" data-kid=\"53\">\n            Zero-Knowledge Proofs: A New Standard for User Privacy\n          </h4>\n          <p class=\"text-sm leading-relaxed text-[#1B1B1B]/70 mb-4 line-clamp-3\" data-kid=\"54\">\n            Implementation details of ZKPs are becoming more accessible to generalist developers.\n          </p>\n          <div class=\"flex items-center justify-between text-[10px] font-bold uppercase tracking-widest border-t border-[#1B1B1B]/10 pt-4\" data-kid=\"55\">\n            <span data-kid=\"56\">2h ago</span>\n            <span class=\"flex items-center gap-1\" data-kid=\"57\"><i class=\"ti ti-message-circle\" data-kid=\"58\"></i> 42</span>\n          </div>\n        </article>\n\n        \n        <article class=\"story-card break-inside-avoid bg-white border border-[#1B1B1B] p-6 hover:shadow-[8px_8px_0px_0px_#1560BD] transition-all duration-300 cursor-pointer group\" data-kid=\"59\">\n          <div class=\"flex justify-between items-start mb-4\" data-kid=\"60\">\n            <span class=\"text-[10px] font-bold uppercase tracking-tighter text-[#1560BD]\" data-kid=\"61\">Ecosystem</span>\n            <i class=\"ti ti-bookmark-filled text-lg text-[#1560BD]\" data-kid=\"62\"></i>\n          </div>\n          <h4 class=\"font-serif text-xl font-black leading-snug mb-3 group-hover:text-[#1560BD] transition-colors\" data-kid=\"63\">\n            Why Rust is Winning the DevTools War in 2026\n          </h4>\n          <p class=\"text-sm leading-relaxed text-[#1B1B1B]/70 mb-4 line-clamp-3\" data-kid=\"64\">\n            From linters to bundlers, the performance ceiling of JavaScript has been hit.\n          </p>\n          <div class=\"flex items-center justify-between text-[10px] font-bold uppercase tracking-widest border-t border-[#1B1B1B]/10 pt-4\" data-kid=\"65\">\n            <span data-kid=\"66\">4h ago</span>\n            <span class=\"flex items-center gap-1\" data-kid=\"67\"><i class=\"ti ti-message-circle\" data-kid=\"68\"></i> 128</span>\n          </div>\n        </article>\n\n        \n        <article class=\"story-card break-inside-avoid bg-white border border-[#1B1B1B] p-6 hover:shadow-[8px_8px_0px_0px_#1560BD] transition-all duration-300 cursor-pointer group\" data-kid=\"69\">\n          <div class=\"flex justify-between items-start mb-4\" data-kid=\"70\">\n            <span class=\"text-[10px] font-bold uppercase tracking-tighter text-[#1560BD]\" data-kid=\"71\">Frontend</span>\n            <i class=\"ti ti-bookmark text-lg hover:text-[#1560BD]\" data-kid=\"72\"></i>\n          </div>\n          <h4 class=\"font-serif text-xl font-black leading-snug mb-3 group-hover:text-[#1560BD] transition-colors\" data-kid=\"73\">\n            Server Actions are No Longer Optional\n          </h4>\n          <p class=\"text-sm leading-relaxed text-[#1B1B1B]/70 mb-4 line-clamp-3\" data-kid=\"74\">\n            The shift towards server-side logic in modern frameworks is complete.\n          </p>\n          <div class=\"flex items-center justify-between text-[10px] font-bold uppercase tracking-widest border-t border-[#1B1B1B]/10 pt-4\" data-kid=\"75\">\n            <span data-kid=\"76\">6h ago</span>\n            <span class=\"flex items-center gap-1\" data-kid=\"77\"><i class=\"ti ti-message-circle\" data-kid=\"78\"></i> 89</span>\n          </div>\n        </article>\n\n        \n        <article class=\"story-card break-inside-avoid bg-white border border-[#1B1B1B] p-6 hover:shadow-[8px_8px_0px_0px_#1560BD] transition-all duration-300 cursor-pointer group\" data-kid=\"79\">\n          <div class=\"flex justify-between items-start mb-4\" data-kid=\"80\">\n            <span class=\"text-[10px] font-bold uppercase tracking-tighter text-[#1560BD]\" data-kid=\"81\">Career</span>\n            <i class=\"ti ti-bookmark text-lg hover:text-[#1560BD]\" data-kid=\"82\"></i>\n          </div>\n          <h4 class=\"font-serif text-xl font-black leading-snug mb-3 group-hover:text-[#1560BD] transition-colors\" data-kid=\"83\">\n            The Rise of the 'Full-Stack Product Engineer'\n          </h4>\n          <p class=\"text-sm leading-relaxed text-[#1B1B1B]/70 mb-4 line-clamp-3\" data-kid=\"84\">\n            Specialization is dead. Long live the generalist who builds features from DB to UI.\n          </p>\n          <div class=\"flex items-center justify-between text-[10px] font-bold uppercase tracking-widest border-t border-[#1B1B1B]/10 pt-4\" data-kid=\"85\">\n            <span data-kid=\"86\">Yesterday</span>\n            <span class=\"flex items-center gap-1\" data-kid=\"87\"><i class=\"ti ti-message-circle\" data-kid=\"88\"></i> 256</span>\n          </div>\n        </article>\n\n        \n        <article class=\"story-card break-inside-avoid bg-white border border-[#1B1B1B] p-6 hover:shadow-[8px_8px_0px_0px_#1560BD] transition-all duration-300 cursor-pointer group\" data-kid=\"89\">\n          <div class=\"flex justify-between items-start mb-4\" data-kid=\"90\">\n            <span class=\"text-[10px] font-bold uppercase tracking-tighter text-[#1560BD]\" data-kid=\"91\">Backend</span>\n            <i class=\"ti ti-bookmark text-lg hover:text-[#1560BD]\" data-kid=\"92\"></i>\n          </div>\n          <h4 class=\"font-serif text-xl font-black leading-snug mb-3 group-hover:text-[#1560BD] transition-colors\" data-kid=\"93\">\n            Postgres is the Only Database You Need (Again)\n          </h4>\n          <p class=\"text-sm leading-relaxed text-[#1B1B1B]/70 mb-4 line-clamp-3\" data-kid=\"94\">\n            How vector support and JSONB improvements killed the niche DB market.\n          </p>\n          <div class=\"flex items-center justify-between text-[10px] font-bold uppercase tracking-widest border-t border-[#1B1B1B]/10 pt-4\" data-kid=\"95\">\n            <span data-kid=\"96\">Yesterday</span>\n            <span class=\"flex items-center gap-1\" data-kid=\"97\"><i class=\"ti ti-message-circle\" data-kid=\"98\"></i> 412</span>\n          </div>\n        </article>\n      </div>\n    </section>\n  </main>\n\n  \n  <footer class=\"bg-[#1B1B1B] text-[#F4F0EC] py-20\" data-kid=\"99\">\n    <div class=\"max-w-7xl mx-auto px-6 grid md:grid-cols-4 gap-12\" data-kid=\"100\">\n      <div class=\"col-span-2\" data-kid=\"101\">\n        <h2 class=\"font-serif text-4xl font-black uppercase mb-6\" data-kid=\"102\">Dev <span class=\"text-[#1560BD]\" data-kid=\"103\">News</span></h2>\n        <p class=\"text-sm opacity-60 leading-relaxed max-w-sm\" data-kid=\"104\">\n          A publication dedicated to the craft of engineering, the ethics of software, and the future of open systems. Printed daily in the digital ether.\n        </p>\n      </div>\n      <div data-kid=\"105\">\n        <h5 class=\"text-xs uppercase font-bold tracking-widest mb-6 text-[#1560BD]\" data-kid=\"106\">Sections</h5>\n        <ul class=\"space-y-3 text-sm font-semibold\" data-kid=\"107\">\n          <li data-kid=\"108\"><a href=\"#\" class=\"hover:underline\" data-kid=\"109\">Security</a></li>\n          <li data-kid=\"110\"><a href=\"#\" class=\"hover:underline\" data-kid=\"111\">Frontend</a></li>\n          <li data-kid=\"112\"><a href=\"#\" class=\"hover:underline\" data-kid=\"113\">Backend</a></li>\n          <li data-kid=\"114\"><a href=\"#\" class=\"hover:underline\" data-kid=\"115\">AI/ML</a></li>\n        </ul>\n      </div>\n      <div data-kid=\"116\">\n        <h5 class=\"text-xs uppercase font-bold tracking-widest mb-6 text-[#1560BD]\" data-kid=\"117\">Social</h5>\n        <ul class=\"space-y-3 text-sm font-semibold\" data-kid=\"118\">\n          <li data-kid=\"119\"><a href=\"#\" class=\"hover:underline\" data-kid=\"120\">X / Twitter</a></li>\n          <li data-kid=\"121\"><a href=\"#\" class=\"hover:underline\" data-kid=\"122\">GitHub</a></li>\n          <li data-kid=\"123\"><a href=\"#\" class=\"hover:underline\" data-kid=\"124\">Discord</a></li>\n          <li data-kid=\"125\"><a href=\"#\" class=\"hover:underline\" data-kid=\"126\">RSS Feed</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"max-w-7xl mx-auto px-6 mt-20 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between gap-4 text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"127\">\n      <p data-kid=\"128\">© 2026 Dev News Application • All Rights Reserved</p>\n      <div class=\"flex gap-8\" data-kid=\"129\">\n        <a href=\"#\" data-kid=\"130\">Privacy Policy</a>\n        <a href=\"#\" data-kid=\"131\">Terms of Service</a>\n        <a href=\"#\" data-kid=\"132\">Ethics Code</a>\n      </div>\n    </div>\n  </footer>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"133\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"134\"></script>\n<script type=\"module\" data-kid=\"135\">\n  import { animate, stagger } from 'https://esm.sh/animejs@4';\n\n  // anime-text-line-mask for hero headline\n  animate('.hero-headline .line-mask', {\n    translateY: ['110%', '0%'],\n    delay: stagger(150),\n    duration: 1000,\n    easing: 'easeOutQuart'\n  });\n\n  // gsap-scroll-batch for story cards\n  gsap.registerPlugin(ScrollTrigger);\n  \n  gsap.set(\".story-card\", { autoAlpha: 0, y: 40 });\n  \n  ScrollTrigger.batch(\".story-card\", {\n    start: \"top 90%\",\n    batchMax: 3,\n    onEnter: (elements) => gsap.to(elements, {\n      autoAlpha: 1,\n      y: 0,\n      stagger: 0.1,\n      duration: 0.8,\n      ease: \"power3.out\",\n      overwrite: true\n    })\n  });\n</script>",
