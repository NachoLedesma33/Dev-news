      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@700;800&family=DM+Sans:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import \"tailwindcss\";\n\n  :root {\n    --color-white: #FFFFFF;\n    --color-whitesmoke: #F5F5F5;\n    --color-onyx: #111111;\n    --color-blaze: #FF5800;\n  }\n\n  body {\n    background-color: var(--color-white);\n    color: var(--color-onyx);\n    font-family: 'DM Sans', sans-serif;\n    margin: 0;\n  }\n\n  .font-heading { font-family: 'Inter', sans-serif; }\n  .border-hairline { border-color: var(--color-onyx); }\n  \n  /* Scroll Progress Bar */\n  #progress-bar {\n    position: fixed;\n    top: 0;\n    left: 0;\n    height: 3px;\n    background: var(--color-blaze);\n    width: 0%;\n    z-index: 100;\n  }\n</style>\n\n<div id=\"progress-bar\" data-kid=\"1\"></div>\n\n\n<header class=\"header sticky top-0 z-50 bg-[var(--color-white)] border-b border-hairline\" data-kid=\"2\">\n  <div class=\"max-w-[1280px] mx-auto h-16 flex items-center px-6 gap-8\" data-kid=\"3\">\n    <div class=\"font-heading font-extrabold text-2xl tracking-tighter shrink-0\" data-kid=\"4\">\n      DEV.NEWS\n    </div>\n    \n    <div class=\"flex-1 flex justify-center\" data-kid=\"5\">\n      <div class=\"relative w-full max-w-2xl\" data-kid=\"6\">\n        <span class=\"absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground\" data-kid=\"7\">\n          <i class=\"ti ti-search text-lg\" data-kid=\"8\"></i>\n        </span>\n        <input type=\"text\" placeholder=\"SEARCH ARTICLES, TAGS, DISCUSSIONS...\" class=\"w-full bg-[var(--color-whitesmoke)] border border-hairline py-2 pl-10 pr-4 text-xs font-bold tracking-widest uppercase rounded-sm focus:outline-hidden focus:ring-1 ring-[var(--color-blaze)]\" data-kid=\"9\">\n      </div>\n    </div>\n    \n    <div class=\"flex items-center gap-6 shrink-0\" data-kid=\"10\">\n      <button class=\"hover:text-[var(--color-blaze)] cursor-pointer\" data-kid=\"11\">\n        <i class=\"ti ti-bookmarks text-xl\" data-kid=\"12\"></i>\n      </button>\n      <button class=\"hover:text-[var(--color-blaze)] cursor-pointer\" data-kid=\"13\">\n        <i class=\"ti ti-moon text-xl\" data-kid=\"14\"></i>\n      </button>\n    </div>\n  </div>\n</header>\n\n<main class=\"max-w-[1280px] mx-auto\" data-kid=\"15\">\n  \n  <section class=\"hero-reveal border-x border-b border-hairline flex min-h-[500px]\" data-kid=\"16\">\n    \n    <div class=\"w-24 border-r border-hairline flex flex-col items-center py-12 gap-8 shrink-0\" data-kid=\"17\">\n      <div class=\"flex flex-col items-center gap-1\" data-kid=\"18\">\n        <span class=\"text-xs font-bold uppercase tracking-tighter text-[var(--color-blaze)]\" data-kid=\"19\">Points</span>\n        <span class=\"font-heading text-2xl font-extrabold\" data-kid=\"20\">842</span>\n      </div>\n      <div class=\"[writing-mode:vertical-rl] rotate-180 text-[10px] font-bold tracking-[0.2em] uppercase text-muted-foreground\" data-kid=\"21\">\n        Featured Execution / July 04\n      </div>\n    </div>\n    \n    \n    <div class=\"flex-1 p-16 flex flex-col justify-center gap-6\" data-kid=\"22\">\n      <div class=\"flex gap-2\" data-kid=\"23\">\n        <span class=\"bg-[var(--color-onyx)] text-[var(--color-white)] px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest\" data-kid=\"24\">Performance</span>\n        <span class=\"border border-hairline px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest\" data-kid=\"25\">Engineering</span>\n      </div>\n      <h1 class=\"font-heading text-6xl font-extrabold leading-[0.9] tracking-tighter\" data-kid=\"26\">\n        THE FUTURE OF <br data-kid=\"27\"> REACT SERVER <br data-kid=\"28\"> COMPONENTS.\n      </h1>\n      <p class=\"max-w-md text-lg leading-snug font-medium\" data-kid=\"29\">\n        Deep dive into the architectural shifts enabling next-gen streaming and partial hydration in the modern web stack.\n      </p>\n      <div class=\"flex items-center gap-4 mt-4\" data-kid=\"30\">\n        <button class=\"bg-[var(--color-blaze)] text-[var(--color-white)] px-8 py-3 text-xs font-bold uppercase tracking-widest rounded-sm hover:bg-[var(--color-onyx)] transition-colors\" data-kid=\"31\">\n          Read Full Story\n        </button>\n        <span class=\"text-xs font-bold uppercase tracking-widest\" data-kid=\"32\">By @dan_abramov</span>\n      </div>\n    </div>\n    \n    \n    <div class=\"w-[400px] border-l border-hairline overflow-hidden shrink-0\" data-kid=\"33\">\n      <img src=\"https://images.unsplash.com/photo-1488972685288-c3fd157d7c7a?auto=format&w=800&q=80&fit=crop\" alt=\"Anders Jildén on Unsplash\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"34\">\n    </div>\n  </section>\n\n  \n  <section class=\"p-6\" data-kid=\"35\">\n    <div class=\"flex items-end justify-between mb-8 border-b border-hairline pb-4\" data-kid=\"36\">\n      <h2 class=\"font-heading text-3xl font-extrabold tracking-tighter uppercase\" data-kid=\"37\">Latest Activity</h2>\n      <div class=\"flex gap-4 text-xs font-bold uppercase tracking-widest\" data-kid=\"38\">\n        <span class=\"text-[var(--color-blaze)] cursor-pointer\" data-kid=\"39\">All</span>\n        <span class=\"text-muted-foreground cursor-pointer hover:text-[var(--color-onyx)]\" data-kid=\"40\">Show HN</span>\n        <span class=\"text-muted-foreground cursor-pointer hover:text-[var(--color-onyx)]\" data-kid=\"41\">Ask HN</span>\n      </div>\n    </div>\n\n    <div class=\"grid divide-y divide-[var(--color-onyx)] border-t border-hairline\" data-kid=\"42\">\n      \n      <div class=\"story-item group flex items-center py-6 gap-8 hover:bg-[var(--color-whitesmoke)] transition-colors\" data-kid=\"43\">\n        <div class=\"w-16 flex flex-col items-center shrink-0\" data-kid=\"44\">\n          <button class=\"text-[var(--color-onyx)] hover:text-[var(--color-blaze)]\" data-kid=\"45\">\n            <i class=\"ti ti-arrow-up text-2xl\" data-kid=\"46\"></i>\n          </button>\n          <span class=\"font-bold text-sm\" data-kid=\"47\">124</span>\n        </div>\n        <div class=\"flex-1\" data-kid=\"48\">\n          <div class=\"flex items-center gap-3 mb-1\" data-kid=\"49\">\n            <span class=\"text-[10px] font-bold uppercase text-muted-foreground tracking-widest\" data-kid=\"50\">vercel.com</span>\n            <span class=\"text-[10px] font-bold uppercase text-muted-foreground\" data-kid=\"51\">•</span>\n            <span class=\"text-[10px] font-bold uppercase text-muted-foreground tracking-widest\" data-kid=\"52\">2h ago</span>\n          </div>\n          <h3 class=\"font-heading text-xl font-bold leading-tight group-hover:text-[var(--color-blaze)] transition-colors\" data-kid=\"53\">\n            Next.js 15: The compilation era begins with Turbopack.\n          </h3>\n        </div>\n        <div class=\"flex items-center gap-12 px-8 shrink-0\" data-kid=\"54\">\n          <div class=\"flex items-center gap-2\" data-kid=\"55\">\n            <i class=\"ti ti-message-circle text-lg\" data-kid=\"56\"></i>\n            <span class=\"text-xs font-bold\" data-kid=\"57\">42</span>\n          </div>\n          <button class=\"text-[var(--color-onyx)] hover:text-[var(--color-blaze)]\" data-kid=\"58\">\n            <i class=\"ti ti-bookmark text-xl\" data-kid=\"59\"></i>\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"story-item group flex items-center py-6 gap-8 hover:bg-[var(--color-whitesmoke)] transition-colors\" data-kid=\"60\">\n        <div class=\"w-16 flex flex-col items-center shrink-0\" data-kid=\"61\">\n          <button class=\"text-[var(--color-onyx)] hover:text-[var(--color-blaze)]\" data-kid=\"62\">\n            <i class=\"ti ti-arrow-up text-2xl\" data-kid=\"63\"></i>\n          </button>\n          <span class=\"font-bold text-sm\" data-kid=\"64\">89</span>\n        </div>\n        <div class=\"flex-1\" data-kid=\"65\">\n          <div class=\"flex items-center gap-3 mb-1\" data-kid=\"66\">\n            <span class=\"text-[10px] font-bold uppercase text-muted-foreground tracking-widest\" data-kid=\"67\">github.com</span>\n            <span class=\"text-[10px] font-bold uppercase text-muted-foreground\" data-kid=\"68\">•</span>\n            <span class=\"text-[10px] font-bold uppercase text-muted-foreground tracking-widest\" data-kid=\"69\">4h ago</span>\n          </div>\n          <h3 class=\"font-heading text-xl font-bold leading-tight group-hover:text-[var(--color-blaze)] transition-colors\" data-kid=\"70\">\n            SQLite is all you need for small to medium scale apps.\n          </h3>\n        </div>\n        <div class=\"flex items-center gap-12 px-8 shrink-0\" data-kid=\"71\">\n          <div class=\"flex items-center gap-2\" data-kid=\"72\">\n            <i class=\"ti ti-message-circle text-lg\" data-kid=\"73\"></i>\n            <span class=\"text-xs font-bold\" data-kid=\"74\">156</span>\n          </div>\n          <button class=\"text-[var(--color-onyx)] hover:text-[var(--color-blaze)]\" data-kid=\"75\">\n            <i class=\"ti ti-bookmark text-xl\" data-kid=\"76\"></i>\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"story-item group flex items-center py-6 gap-8 hover:bg-[var(--color-whitesmoke)] transition-colors\" data-kid=\"77\">\n        <div class=\"w-16 flex flex-col items-center shrink-0\" data-kid=\"78\">\n          <button class=\"text-[var(--color-onyx)] hover:text-[var(--color-blaze)]\" data-kid=\"79\">\n            <i class=\"ti ti-arrow-up text-2xl\" data-kid=\"80\"></i>\n          </button>\n          <span class=\"font-bold text-sm\" data-kid=\"81\">215</span>\n        </div>\n        <div class=\"flex-1\" data-kid=\"82\">\n          <div class=\"flex items-center gap-3 mb-1\" data-kid=\"83\">\n            <span class=\"text-[10px] font-bold uppercase text-muted-foreground tracking-widest\" data-kid=\"84\">openai.com</span>\n            <span class=\"text-[10px] font-bold uppercase text-muted-foreground\" data-kid=\"85\">•</span>\n            <span class=\"text-[10px] font-bold uppercase text-muted-foreground tracking-widest\" data-kid=\"86\">6h ago</span>\n          </div>\n          <h3 class=\"font-heading text-xl font-bold leading-tight group-hover:text-[var(--color-blaze)] transition-colors\" data-kid=\"87\">\n            Introducing GPT-5: Reasoning beyond language.\n          </h3>\n        </div>\n        <div class=\"flex items-center gap-12 px-8 shrink-0\" data-kid=\"88\">\n          <div class=\"flex items-center gap-2\" data-kid=\"89\">\n            <i class=\"ti ti-message-circle text-lg\" data-kid=\"90\"></i>\n            <span class=\"text-xs font-bold\" data-kid=\"91\">892</span>\n          </div>\n          <button class=\"text-[var(--color-blaze)]\" data-kid=\"92\">\n            <i class=\"ti ti-bookmark-filled text-xl\" data-kid=\"93\"></i>\n          </button>\n        </div>\n      </div>\n    </div>\n  </section>\n</main>\n\n<footer class=\"border-t border-hairline mt-24 py-12\" data-kid=\"94\">\n  <div class=\"max-w-[1280px] mx-auto px-6 flex justify-between items-start\" data-kid=\"95\">\n    <div class=\"flex flex-col gap-4\" data-kid=\"96\">\n      <div class=\"font-heading font-extrabold text-xl tracking-tighter\" data-kid=\"97\">DEV.NEWS</div>\n      <p class=\"text-xs font-medium max-w-xs leading-relaxed text-muted-foreground\" data-kid=\"98\">\n        Curated intelligence for the modern engineer. Built on structural honesty and data clarity.\n      </p>\n    </div>\n    <div class=\"grid grid-cols-2 gap-24\" data-kid=\"99\">\n      <div class=\"flex flex-col gap-4\" data-kid=\"100\">\n        <h4 class=\"text-xs font-bold uppercase tracking-widest\" data-kid=\"101\">Network</h4>\n        <nav class=\"flex flex-col gap-2 text-xs font-medium uppercase text-muted-foreground\" data-kid=\"102\">\n          <a href=\"#\" class=\"hover:text-[var(--color-onyx)]\" data-kid=\"103\">Submissions</a>\n          <a href=\"#\" class=\"hover:text-[var(--color-onyx)]\" data-kid=\"104\">Top Stories</a>\n          <a href=\"#\" class=\"hover:text-[var(--color-onyx)]\" data-kid=\"105\">Newsletter</a>\n        </nav>\n      </div>\n      <div class=\"flex flex-col gap-4\" data-kid=\"106\">\n        <h4 class=\"text-xs font-bold uppercase tracking-widest\" data-kid=\"107\">Legal</h4>\n        <nav class=\"flex flex-col gap-2 text-xs font-medium uppercase text-muted-foreground\" data-kid=\"108\">\n          <a href=\"#\" class=\"hover:text-[var(--color-onyx)]\" data-kid=\"109\">Privacy</a>\n          <a href=\"#\" class=\"hover:text-[var(--color-onyx)]\" data-kid=\"110\">Terms</a>\n          <a href=\"#\" class=\"hover:text-[var(--color-onyx)]\" data-kid=\"111\">Source</a>\n        </nav>\n      </div>\n    </div>\n  </div>\n</footer>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"112\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"113\"></script>\n<script type=\"module\" data-kid=\"114\">\n  import { animate, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import Lenis from \"https://esm.sh/lenis@1\"\n\n  // 1. Lenis Smooth Scroll\n  const lenis = new Lenis();\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // 2. Scroll Progress readout\n  lenis.on('scroll', ({ progress }) => {\n    document.getElementById('progress-bar').style.width = `${progress * 100}%`;\n  });\n\n  // 3. Motion: Scroll-Aware Header Hide\n  scroll((p, info) => {\n    if (info.y.velocity > 0 && info.y.current > 100) {\n      animate(\".header\", { y: \"-100%\" }, { duration: 0.25, ease: \"easeOut\" });\n    } else if (info.y.velocity < 0) {\n      animate(\".header\", { y: \"0%\" }, { duration: 0.3, ease: \"easeOut\" });\n    }\n  });\n\n  // 4. GSAP: Entrance Reveals\n  gsap.registerPlugin(ScrollTrigger);\n  \n  // Hero reveal\n  gsap.from(\".hero-reveal > *\", {\n    autoAlpha: 0,\n    y: 30,\n    duration: 0.8,\n    stagger: 0.1,\n    ease: \"power3.out\"\n  });\n\n  // List reveal\n  gsap.from(\".story-item\", {\n    scrollTrigger: {\n      trigger: \".story-item\",\n      start: \"top 85%\"\n    },\n    autoAlpha: 0,\n    y: 20,\n    duration: 0.5,\n    stagger: 0.05,\n    ease: \"power2.out\"\n  });\n</script>",
